{"type":"data","nodes":[null,{"type":"data","data":[{"projects":1},[2],{"title":3,"slug":4,"description":5,"excerpt":6,"coverImage":7,"date":8,"tags":9,"techStack":13,"github":19,"status":20,"featured":21,"hidden":22,"html":23},"RescueVision Edge","rescuevision-edge","SAR victim detection on drone imagery with YOLOv8n ONNX, fully on-device, sub-40ms latency.","Real-time victim detection for Search & Rescue drones — YOLOv8n quantized ONNX running fully on-device with sub-40ms inference and DJI EXIF GPS fusion.","images\u002Ffeatures\u002Frescuevision.jpg","2026-03-15T00:00:00.000Z",[10,11,12],"Computer Vision","Edge AI","Search & Rescue",[14,15,16,17,18],"YOLOv8n","ONNX Runtime","FastAPI","DJI EXIF GPS","PyTorch","https:\u002F\u002Fgithub.com\u002Fjaweed3\u002FRescueVision","active",true,false,"\u003Ch2 id=\"architecture-overview\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#architecture-overview\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003EArchitecture Overview\u003C\u002Fh2\u003E\n\u003Cp\u003ERescueVision Edge runs a quantized YOLOv8n model directly on drone-captured imagery. The entire pipeline — preprocessing, inference, and postprocessing — executes on-device with no cloud dependency.\u003C\u002Fp\u003E\n\u003Ch3 id=\"pipeline\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#pipeline\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003EPipeline\u003C\u002Fh3\u003E\n\u003Cpre class=\"language-undefined\"\u003E\u003C!-- HTML_TAG_START --\u003E\u003Ccode class=\"language-undefined\"\u003EDrone Feed → Frame Extraction → Preprocessing → ONNX Inference → NMS → GPS Fusion → Alert\u003C\u002Fcode\u003E\u003C!-- HTML_TAG_END --\u003E\u003C\u002Fpre\u003E\n\u003Ch2 id=\"quantization-strategy\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#quantization-strategy\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003EQuantization Strategy\u003C\u002Fh2\u003E\n\u003Cp\u003EWe apply INT8 quantization via ONNX Runtime to compress the FP32 YOLOv8n model while preserving detection accuracy.\u003C\u002Fp\u003E\n\u003Cp\u003EThe quantization formula for weights:\u003C\u002Fp\u003E\n\u003Cpre class=\"language-undefined\"\u003E\u003C!-- HTML_TAG_START --\u003E\u003Ccode class=\"language-undefined\"\u003EW_int8 = round(W_fp32 \u002F scale) + zero_point\u003C\u002Fcode\u003E\u003C!-- HTML_TAG_END --\u003E\u003C\u002Fpre\u003E\n\u003Cp\u003EWhere the scale and zero-point are calibrated per-channel using symmetric quantization:\u003C\u002Fp\u003E\n\u003Cpre class=\"language-undefined\"\u003E\u003C!-- HTML_TAG_START --\u003E\u003Ccode class=\"language-undefined\"\u003Escale = max(|W_fp32|) \u002F 127\u003C\u002Fcode\u003E\u003C!-- HTML_TAG_END --\u003E\u003C\u002Fpre\u003E\n\u003Ch3 id=\"latency-breakdown\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#latency-breakdown\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003ELatency Breakdown\u003C\u002Fh3\u003E\n\u003Cp\u003E\u003Ccode\u003Et_total = t_pre + t_infer + t_post = 5ms + 28ms + 6ms &lt; 40ms\u003C\u002Fcode\u003E\u003C\u002Fp\u003E\n\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EPreprocessing\u003C\u002Fstrong\u003E (\u003Ccode\u003E5ms\u003C\u002Fcode\u003E): Resize to \u003Ccode\u003E640x640\u003C\u002Fcode\u003E, normalize to \u003Ccode\u003E[0, 1]\u003C\u002Fcode\u003E\u003C\u002Fli\u003E\n\u003Cli\u003E\u003Cstrong\u003EInference\u003C\u002Fstrong\u003E (\u003Ccode\u003E28ms\u003C\u002Fcode\u003E): ONNX Runtime with INT8 execution provider\u003C\u002Fli\u003E\n\u003Cli\u003E\u003Cstrong\u003EPostprocessing\u003C\u002Fstrong\u003E (\u003Ccode\u003E6ms\u003C\u002Fcode\u003E): NMS with IoU threshold \u003Ccode\u003E0.45\u003C\u002Fcode\u003E, confidence threshold \u003Ccode\u003E0.50\u003C\u002Fcode\u003E\u003C\u002Fli\u003E\u003C\u002Ful\u003E\n\u003Ch2 id=\"detection-performance\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#detection-performance\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003EDetection Performance\u003C\u002Fh2\u003E\n\u003Ctable\u003E\u003Cthead\u003E\u003Ctr\u003E\u003Cth\u003EMetric\u003C\u002Fth\u003E\n\u003Cth\u003EFP32\u003C\u002Fth\u003E\n\u003Cth\u003EINT8\u003C\u002Fth\u003E\n\u003Cth\u003EDelta\u003C\u002Fth\u003E\u003C\u002Ftr\u003E\u003C\u002Fthead\u003E\n\u003Ctbody\u003E\u003Ctr\u003E\u003Ctd\u003E\u003Ca href=\"mailto:mAP@0.5\"\u003EmAP@0.5\u003C\u002Fa\u003E\u003C\u002Ftd\u003E\n\u003Ctd\u003E0.892\u003C\u002Ftd\u003E\n\u003Ctd\u003E0.884\u003C\u002Ftd\u003E\n\u003Ctd\u003E-0.9%\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\n\u003Ctr\u003E\u003Ctd\u003E\u003Ca href=\"mailto:mAP@0.5\"\u003EmAP@0.5\u003C\u002Fa\u003E:0.95\u003C\u002Ftd\u003E\n\u003Ctd\u003E0.671\u003C\u002Ftd\u003E\n\u003Ctd\u003E0.658\u003C\u002Ftd\u003E\n\u003Ctd\u003E-1.9%\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\n\u003Ctr\u003E\u003Ctd\u003ELatency (ms)\u003C\u002Ftd\u003E\n\u003Ctd\u003E45.2\u003C\u002Ftd\u003E\n\u003Ctd\u003E28.4\u003C\u002Ftd\u003E\n\u003Ctd\u003E-37%\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\n\u003Ctr\u003E\u003Ctd\u003EModel Size (MB)\u003C\u002Ftd\u003E\n\u003Ctd\u003E12.4\u003C\u002Ftd\u003E\n\u003Ctd\u003E3.6\u003C\u002Ftd\u003E\n\u003Ctd\u003E-71%\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003C\u002Ftbody\u003E\u003C\u002Ftable\u003E\n\u003Ch2 id=\"gps-fusion\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#gps-fusion\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003EGPS Fusion\u003C\u002Fh2\u003E\n\u003Cp\u003EEach detection is geotagged using DJI EXIF metadata embedded in the drone imagery:\u003C\u002Fp\u003E\n\u003Cdiv class=\"code-block svelte-1pkpsrg\"\u003E\u003Cdiv class=\"filename svelte-1pkpsrg\"\u003Egeotag.py\u003C\u002Fdiv\u003E\n\t\u003Cdiv class=\"lang svelte-1pkpsrg\"\u003Epython\u003C\u002Fdiv\u003E\n\t\u003Cpre class=\"language-python\"\u003E\u003C!-- HTML_TAG_START --\u003E\u003Ccode class=\"language-python\"\u003E\u003Cspan class=\"token keyword\"\u003Edef\u003C\u002Fspan\u003E \u003Cspan class=\"token function\"\u003Epixel_to_gps\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Ebbox\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E drone_lat\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E drone_lon\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E altitude\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E fov\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E image_size\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E\n    \u003Cspan class=\"token triple-quoted-string string\"\u003E\"\"\"\n    Convert bounding box center to GPS coordinates\n    using drone telemetry from DJI EXIF.\n    \"\"\"\u003C\u002Fspan\u003E\n    cx \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Ebbox\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E0\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E+\u003C\u002Fspan\u003E bbox\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E2\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E\u002F\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E2\u003C\u002Fspan\u003E\n    cy \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Ebbox\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E1\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E+\u003C\u002Fspan\u003E bbox\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E3\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E\u002F\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E2\u003C\u002Fspan\u003E\n\n    \u003Cspan class=\"token comment\"\u003E# Angular offset from drone nadir\u003C\u002Fspan\u003E\n    dx \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Ecx \u003Cspan class=\"token operator\"\u003E\u002F\u003C\u002Fspan\u003E image_size\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E0\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E-\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E0.5\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E*\u003C\u002Fspan\u003E fov\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E0\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E\n    dy \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Ecy \u003Cspan class=\"token operator\"\u003E\u002F\u003C\u002Fspan\u003E image_size\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E1\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E-\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E0.5\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E*\u003C\u002Fspan\u003E fov\u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E1\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E\n\n    \u003Cspan class=\"token comment\"\u003E# Ground distance\u003C\u002Fspan\u003E\n    gsd \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E altitude \u003Cspan class=\"token operator\"\u003E*\u003C\u002Fspan\u003E tan\u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Eradians\u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Edx\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\n    lat_offset \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E gsd \u003Cspan class=\"token operator\"\u003E\u002F\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E111320\u003C\u002Fspan\u003E  \u003Cspan class=\"token comment\"\u003E# meters per degree lat\u003C\u002Fspan\u003E\n    lon_offset \u003Cspan class=\"token operator\"\u003E=\u003C\u002Fspan\u003E gsd \u003Cspan class=\"token operator\"\u003E\u002F\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003E\u003Cspan class=\"token number\"\u003E111320\u003C\u002Fspan\u003E \u003Cspan class=\"token operator\"\u003E*\u003C\u002Fspan\u003E cos\u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Eradians\u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Edrone_lat\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\n\n    \u003Cspan class=\"token keyword\"\u003Ereturn\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E(\u003C\u002Fspan\u003Edrone_lat \u003Cspan class=\"token operator\"\u003E+\u003C\u002Fspan\u003E lat_offset\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E drone_lon \u003Cspan class=\"token operator\"\u003E+\u003C\u002Fspan\u003E lon_offset\u003Cspan class=\"token punctuation\"\u003E)\u003C\u002Fspan\u003E\u003C\u002Fcode\u003E\u003C!-- HTML_TAG_END --\u003E\u003C\u002Fpre\u003E\n\u003C\u002Fdiv\u003E\n\u003Ch2 id=\"api-endpoint\"\u003E\u003Ca class=\"heading-link\" title=\"Permalink\" aria-hidden=\"true\" href=\"#api-endpoint\"\u003E\u003Cspan\u003E#\u003C\u002Fspan\u003E\u003C\u002Fa\u003EAPI Endpoint\u003C\u002Fh2\u003E\n\u003Cp\u003EThe FastAPI server exposes a single inference endpoint:\u003C\u002Fp\u003E\n\u003Cdiv class=\"code-block svelte-1pkpsrg\"\u003E\u003Cdiv class=\"filename svelte-1pkpsrg\"\u003Eopenapi.yaml\u003C\u002Fdiv\u003E\n\t\u003Cdiv class=\"lang svelte-1pkpsrg\"\u003Eyaml\u003C\u002Fdiv\u003E\n\t\u003Cpre class=\"language-yaml\"\u003E\u003C!-- HTML_TAG_START --\u003E\u003Ccode class=\"language-yaml\"\u003EPOST \u002Fdetect\n  \u003Cspan class=\"token key atrule\"\u003EContent-Type\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E multipart\u002Fform\u003Cspan class=\"token punctuation\"\u003E-\u003C\u002Fspan\u003Edata\n  \u003Cspan class=\"token key atrule\"\u003EParameters\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E\n    \u003Cspan class=\"token punctuation\"\u003E-\u003C\u002Fspan\u003E \u003Cspan class=\"token key atrule\"\u003Eimage\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E file (JPEG\u002FPNG\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E drone capture)\n    \u003Cspan class=\"token punctuation\"\u003E-\u003C\u002Fspan\u003E \u003Cspan class=\"token key atrule\"\u003Econfidence\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E float = 0.5\n    \u003Cspan class=\"token punctuation\"\u003E-\u003C\u002Fspan\u003E \u003Cspan class=\"token key atrule\"\u003Eiou\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E float = 0.45\n  \u003Cspan class=\"token key atrule\"\u003EResponse\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E\n    \u003Cspan class=\"token key atrule\"\u003Edetections\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E\n      \u003Cspan class=\"token punctuation\"\u003E-\u003C\u002Fspan\u003E \u003Cspan class=\"token key atrule\"\u003Ebbox\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003Ex1\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E y1\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E x2\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E y2\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E\n        \u003Cspan class=\"token key atrule\"\u003Eclass\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E \u003Cspan class=\"token string\"\u003E\"person\"\u003C\u002Fspan\u003E\n        \u003Cspan class=\"token key atrule\"\u003Econfidence\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E0.94\u003C\u002Fspan\u003E\n        \u003Cspan class=\"token key atrule\"\u003Egps\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E \u003Cspan class=\"token punctuation\"\u003E[\u003C\u002Fspan\u003Elat\u003Cspan class=\"token punctuation\"\u003E,\u003C\u002Fspan\u003E lon\u003Cspan class=\"token punctuation\"\u003E]\u003C\u002Fspan\u003E\n    \u003Cspan class=\"token key atrule\"\u003Elatency_ms\u003C\u002Fspan\u003E\u003Cspan class=\"token punctuation\"\u003E:\u003C\u002Fspan\u003E \u003Cspan class=\"token number\"\u003E38.2\u003C\u002Fspan\u003E\u003C\u002Fcode\u003E\u003C!-- HTML_TAG_END --\u003E\u003C\u002Fpre\u003E\n\u003C\u002Fdiv\u003E"],"uses":{"url":1}}]}
